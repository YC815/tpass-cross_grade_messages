# ── SSO（消費端，只需要公鑰來源與幾個 URL，絕不碰 auth 私鑰）──────
AUTH_JWKS_URL=https://auth.lvh.me:3000/.well-known/jwks.json
AUTH_AUTHORIZE_URL=https://auth.lvh.me:3000/api/auth/authorize
AUTH_LOGOUT_URL=https://auth.lvh.me:3000/api/auth/logout
MSG_SELF_URL=https://msg.lvh.me:3003
# 契約 v2：本服務登記的服務 id（須在 auth 的 AUTH_SERVICE_IDS 白名單內）
TPASS_SERVICE_ID=msg
# 門戶大廳：不同意使用者守則時導回這裡（正式環境換 https://portal.tschoolsu.org）
PORTAL_URL=https://portal.lvh.me:3001
JWT_ISSUER=https://auth.lvh.me:3000

# ── v1 遷移期 fallback（全生態升到 v2、auth 停發共用 cookie 後可整段移除）──
JWT_AUDIENCE=tschool-sso
TPASS_COOKIE_NAME=tpass_session

# ── 超管種子（逗號分隔；其餘管理員登入後由超管在 /admin/members 加）──
SUPER_ADMIN_EMAILS=you@tschool.tp.edu.tw

# ── 資料庫（本機用 tpass db setup 自動建；上線用主機的 per-service user/db）──
DATABASE_URL=postgresql://t_msg@localhost:5432/t_msg

# ── 本機 HTTPS（server.mjs 用）──────────────────────────────────────
# Webhook URL 不放 env：內含 secret，一律由 /admin/webhooks UI 存進 DB。
TLS_KEY_FILE=../certs/key.pem
TLS_CERT_FILE=../certs/cert.pem
PORT=3003
HOSTNAME=msg.lvh.me
